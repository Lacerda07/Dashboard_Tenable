      see_also    : "https://workbench.cisecurity.org/benchmarks/22751"
      cmd         : "#!/usr/bin/ksh -e

{
/usr/bin/find /var/spool/cron/crontabs -type d -prune \\( -perm -4 -o -perm -2 -o -perm -1 -o -perm -200000000 \\) -o ! -user bin -o ! -group cron
/usr/bin/find /var/spool/cron/crontabs \\( -perm -4 -o -perm -2 -o -perm -1 -o -perm -200000000 \\) -o ! -group cron
/usr/sbin/trustchk -n /var/spool/cron/crontabs >/dev/null 2>&1 || echo trustchk failed
} | /usr/bin/awk '{print} END {if (NR == 0) print \"pass\" ; else print \"fail\"}'"
