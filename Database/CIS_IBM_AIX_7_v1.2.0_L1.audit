      see_also    : "https://workbench.cisecurity.org/benchmarks/22751"
      cmd         : "/usr/bin/lssrc -s inetd -l | /usr/bin/grep klogin | /usr/bin/wc -l"
      expect      : "^0$"
    </custom_item>

