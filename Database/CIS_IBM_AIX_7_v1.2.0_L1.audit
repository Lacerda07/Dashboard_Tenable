  ports=$(/usr/bin/awk '/^Port / { print $2 } /^Match (.* )?LocalPort / { for(x=2; x<=NF; x+=2) if ($x == \"LocalPort\") print $(x+1) }' /etc/ssh/sshd_config | /usr/bin/awk '{print $0}; END {if (NR == 0) print \"22\"}' | uniq); for port in ${ports[@]}; do /usr/sbin/sshd -T -C user=root -C host=\"$(hostname)\" -C addr=\"$(/usr/bin/grep $(hostname) /etc/hosts | /usr/bin/awk '{print $1}')\" -C lport=$port | echo \"port $port: $(/usr/bin/grep -iE \"(allow|deny)(users|groups)\")\"; done | /usr/bin/grep -iE \"(AllowUsers|AllowGroups|DenyUsers|DenyGroups)\" | /usr/bin/awk '{print} END {if (NR != 0) print \"pass\"; else print \"fail\"}'
