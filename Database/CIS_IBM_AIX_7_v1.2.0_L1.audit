{
for dir in /etc/security/audit /audit; do
  [ -d \"$dir\" ] && /usr/bin/find \"$dir\" \\( ! -name 'lost+found' \\) \\( ! -user root -o ! -group audit -o -perm -4 -o -perm -2 -o -perm -1 \\) -exec /usr/bin/ls -ld {} \\;
